          "rawSql": "SELECT $__timeGroupAlias(finished_at, '1d'), 'p50' AS metric, avg(p50_ms)::double precision AS value\nFROM verification_runs\nWHERE $__timeFilter(finished_at)\n  AND test_key = 'response_time'\nGROUP BY 1\nUNION ALL\nSELECT $__timeGroupAlias(finished_at, '1d'), 'p95' AS metric, avg(p95_ms)::double precision AS value\nFROM verification_runs\nWHERE $__timeFilter(finished_at)\n  AND test_key = 'response_time'\nGROUP BY 1\nORDER BY 1, 2",

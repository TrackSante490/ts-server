        {
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT $__timeGroupAlias(started_at, '1d'), COALESCE(NULLIF(meta->>'last_recommended_sensor', ''), 'NO_DECISION') AS metric, count(*)::double precision AS value\nFROM user_sessions\nWHERE $__timeFilter(started_at)\n  AND COALESCE(meta->>'source', '') = 'api_chat'\nGROUP BY 1, 2\nORDER BY 1, 2",
          "refId": "A"
        }
      ],
      "title": "Chat Session Growth by Recommended Sensor",
      "type": "timeseries"

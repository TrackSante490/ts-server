# --- API auth (if you enforce it) ---
API_KEYS=your_key_1,your_key_2

# --- Postgres (used by your API code if it reads DATABASE_URL) ---
DATABASE_URL=postgresql://postgres:postgres@db:5432/postgres

# --- MinIO / S3 (used by ingestion + image storage) ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET_IMAGES=images

# --- RAG / Ollama configuration (used by cappie_run via env) ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=llama3.1
OLLAMA_EMBED_MODEL=nomic-embed-text

# Optional: where cappie_run stores session files (if you add support)
# RAG_STATE_DIR=/cappie_run/rag_state
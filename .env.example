# --- API auth (if you enforce it) ---
API_KEYS=your_key_1,your_key_2

# --- Postgres (used by your API code if it reads DATABASE_URL) ---
DATABASE_URL=postgresql://postgres:postgres@db:5432/postgres

# --- MinIO / S3 (used by ingestion + image storage) ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET_IMAGES=images

# --- RAG / Ollama configuration (used by cappie_run via env) ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=llama3.1
OLLAMA_EMBED_MODEL=nomic-embed-text
# Keep the chat model resident to avoid cold starts.
OLLAMA_KEEP_ALIVE=-1
# Keep both chat and embedding models resident when VRAM allows.
OLLAMA_MAX_LOADED_MODELS=2
# Avoid extra parallel workers increasing KV-cache pressure.
OLLAMA_NUM_PARALLEL=1
# Max patient profile file upload size in MB (PDF endpoint)
PROFILE_FILE_MAX_MB=20
# Timeout for dependency probes exposed on /metrics
METRICS_PROBE_TIMEOUT_SECONDS=2.0

# --- Grafana / observability ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_DOMAIN=grafana.tracksante.com
GRAFANA_ROOT_URL=https://grafana.tracksante.com
# Keep these aligned with your Postgres settings above if you customize them.
GRAFANA_POSTGRES_URL=db:5432
GRAFANA_POSTGRES_DB=postgres
GRAFANA_POSTGRES_USER=postgres
GRAFANA_POSTGRES_PASSWORD=postgres

# Optional: where cappie_run stores session files (if you add support)
# RAG_STATE_DIR=/cappie_run/rag_state
